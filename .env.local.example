# ─────────────────────────────────────────────────────────────────
# CompoundIQ — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# ── Iron-Session Encryption Key (REQUIRED) ────────────────────────
# Must be a random 64-character hex string.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_64_char_hex_string

# ── Alpha Vantage (OPTIONAL) ──────────────────────────────────────
# Used server-side as a fallback if the user hasn't provided their own key.
# Get a free key at: https://www.alphavantage.co/support/#api-key
# Note: free tier is limited to 25 requests/day.
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ── Trading 212 Base URL (OPTIONAL) ──────────────────────────────
# Defaults to the live API. Override for demo/paper accounts.
# TRADING212_BASE_URL=https://live.trading212.com/api/v0
